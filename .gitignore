# Dependencies installed by npm.
node_modules

# Build output produced by `npm run build`, `npm run test:exports`, and package dry runs.
dist

# Coverage output produced by `npm run coverage`.
coverage

# Tool caches.
.eslintcache

# Husky runtime files generated by `npm run hooks:install`; hook definitions stay committed.
.husky/_

# Local package archives produced by npm.
*.tgz

# Local IDE/editor state.
.idea
.vscode

# OS metadata.
.DS_Store

# Local environment files. Keep real secrets out of git.
.env
.env.*
